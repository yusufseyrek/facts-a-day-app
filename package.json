{
  "name": "facts-a-day-app",
  "version": "1.2.7",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "clean": "npx expo prebuild --clean",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --forceExit --coverage --collectCoverageFrom='src/services/**/*.ts' --collectCoverageFrom='src/utils/insertNativeAds.ts'",
    "build:ios": "./scripts/build-ios.sh",
    "build:android": "./scripts/build-android.sh",
    "update:ios": "./scripts/publish-update.sh ios",
    "update:android": "./scripts/publish-update.sh android",
    "update:all": "./scripts/publish-update.sh all"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-view-shot"
      ]
    }
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./src/__tests__/setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "testTimeout": 1e4,
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|tamagui|@tamagui/.*|i18n-js|react-native-google-mobile-ads|react-native-reanimated|react-native-gesture-handler|react-native-screens|react-native-safe-area-context|react-native-worklets)"
    ],
    "moduleNameMapper": {
      "^@react-native-firebase/app$": "<rootDir>/src/__tests__/__mocks__/firebase/app.ts",
      "^@react-native-firebase/app-check$": "<rootDir>/src/__tests__/__mocks__/firebase/appCheck.ts",
      "^@react-native-firebase/analytics$": "<rootDir>/src/__tests__/__mocks__/firebase/analytics.ts",
      "^@react-native-firebase/crashlytics$": "<rootDir>/src/__tests__/__mocks__/firebase/crashlytics.ts"
    }
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/app-check": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@shopify/flash-list": "2.0.2",
    "@tamagui/core": "^1.136.2",
    "@tamagui/lucide-icons": "^1.136.2",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "expo": "^56.0.0-preview.10",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.8",
    "expo-audio": "~56.0.5",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.7",
    "expo-constants": "~56.0.8",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.4",
    "expo-font": "~56.0.3",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-iap": "^3.4.8",
    "expo-image": "~56.0.4",
    "expo-image-manipulator": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.6",
    "expo-localization": "~56.0.4",
    "expo-navigation-bar": "~56.0.3",
    "expo-network": "~56.0.3",
    "expo-notifications": "~56.0.7",
    "expo-router": "~56.1.4",
    "expo-sharing": "~56.0.7",
    "expo-splash-screen": "~56.0.5",
    "expo-sqlite": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-tracking-transparency": "~56.0.4",
    "expo-updates": "~56.0.8",
    "expo-web-browser": "~56.0.4",
    "i18n-js": "^4.5.1",
    "posthog-react-native": "^4.45.5",
    "posthog-react-native-session-replay": "^1.5.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-google-mobile-ads": "16.3.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "^5.1.0",
    "react-native-worklets": "0.8.3",
    "tamagui": "^1.136.2"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.1",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3"
  },
  "private": true,
  "patchedDependencies": {
    "react-native-google-mobile-ads@16.3.3": "patches/react-native-google-mobile-ads@16.3.3.patch"
  }
}
